# Auto-detect text files and normalize line endings
* text=auto

# Python source
*.py text diff=python
*.pyw text

# TypeScript source
*.ts text diff=typescript
*.tsx text

# Configuration
*.toml text
*.ini text
*.cfg text
*.json text
*.yaml text
*.yml text

# Documentation
*.md text diff=markdown
*.rst text
*.txt text

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Batch scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Git files
.gitattributes text
.gitignore text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.eot binary
*.ttf binary
*.otf binary
*.ico binary
*.zip binary
*.tar.gz binary
*.gz binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.pyc binary
*.pyo binary
