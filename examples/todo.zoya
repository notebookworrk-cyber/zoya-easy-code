// Todo List App
fn main() {
    tasks = []

    loop 5 {
        print "1. Add task"
        print "2. List tasks"
        print "3. Quit"
        choice = input("Choose: ")

        if choice == "1" {
            task = input("Enter task: ")
            tasks.append(task)
            print "Task added!"
        }

        if choice == "2" {
            for t in tasks {
                print t
            }
        }

        if choice == "3" { break }
    }
}
main()
